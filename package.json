{
  "name": "astro-login",
  "version": "1.0.0",
  "author": "Jumpei Ogawa (https://phanective.org)",
  "contributors": [
    "pilcrowOnPaper"
  ],
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "workspaces/*"
  ],
  "scripts": {
    "dev": "lerna run dev --stream --parallel",
    "build": "lerna run build --stream",
    "lint": "lerna exec -- tsc --noEmit && eslint",
    "fix": "eslint --fix",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm run clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install && pnpm run build"
  },
  "devDependencies": {
    "@lerna-lite/cli": "^3.10.0",
    "@lerna-lite/exec": "^3.10.0",
    "@lerna-lite/run": "^3.10.0",
    "@phanect/configs": "latest",
    "@phanect/lint": "latest",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "shx": "^0.3.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "20.x || >=22.x",
    "pnpm": ">=9.x"
  },
  "packageManager": "pnpm@9.13.0+sha512.beb9e2a803db336c10c9af682b58ad7181ca0fbd0d4119f2b33d5f2582e96d6c0d93c85b23869295b765170fbdaa92890c0da6ada457415039769edf3c959efe"
}
