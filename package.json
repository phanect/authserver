{
  "name": "astro-login",
  "version": "1.0.0",
  "author": "Jumpei Ogawa (https://phanective.org)",
  "contributors": [
    "pilcrowOnPaper"
  ],
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "workspaces/*"
  ],
  "scripts": {
    "dev": "lerna run dev",
    "build": "lerna run build",
    "lint": "lerna exec -- tsc --noEmit && eslint",
    "fix": "eslint --fix",
    "clean": "git clean -dX --exclude=\"!.env\" --force",
    "refresh": "pnpm run clean && rm --force ./pnpm-lock.yaml && corepack up && pnpm install && pnpm run build"
  },
  "devDependencies": {
    "@lerna-lite/cli": "^3.10.0",
    "@lerna-lite/exec": "^3.10.0",
    "@lerna-lite/run": "^3.10.0",
    "@phanect/configs": "latest",
    "@phanect/lint": "latest",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "shx": "^0.3.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "20.x || >=22.x",
    "pnpm": ">=9.x"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
